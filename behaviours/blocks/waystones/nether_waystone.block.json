{
    "format_version": "1.26.20",
    "minecraft:block": {
        "description": {
            "identifier": "tcsmp:nether_waystone",
            "states": {
                "tcsmp:active": [false, true]
            },
            "traits": {
                "minecraft:multi_block": {
                    "enabled_states": ["minecraft:multi_block_part"],
                    "parts": 2,
                    "direction": "up"
                }
            }
        },
        "components": {
            "tcsmp:waystone": {
                "dimension": "minecraft:nether"
            },
            "minecraft:tags": [
                "minecraft:is_pickaxe_item_destructible",
                "minecraft:diamond_tier_destructible"
            ],
            "minecraft:geometry": {
                "identifier": "geometry.waystone_bottom",
                "culling": "tcsmp:culling.waystone.bottom"
            },
            "minecraft:material_instances": {
                "*": {
                    "render_method": "opaque"
                },
                "side_top": {
                    "texture": "nether_waystone_side_top"
                },
                "side_bottom": {
                    "texture": "nether_waystone_side_bottom"
                },
                "up": {
                    "texture": "nether_waystone_interior"
                },
                "down": {
                    "texture": "nether_waystone_exterior"
                }
            },
            "minecraft:placement_filter": {
                "conditions": [{
                    "allowed_faces": ["up"]
                }]
            },
            "minecraft:loot": "loot_tables/blocks/nether_waystone.json",
            "minecraft:destructible_by_explosion": false,
            "minecraft:destructible_by_mining": {
                "seconds_to_destroy": 50
            },
            "minecraft:map_color": "#3C3947",
            "minecraft:light_dampening": 7,
            "minecraft:liquid_detection": {
                "detection_rules": [{
                    "liquid_type": "water",
                    "can_contain_liquid": true
                }]
            },
            "minecraft:precipitation_interactions": {
                "precipitation_behavior": "obstruct_rain"
            },
            "minecraft:chest_obstruction": {
                "obstruction_rule": "always"
            },
            "minecraft:redstone_conductivity": {
                "allows_wire_to_step_down": false
            },
            "minecraft:movable": {
                "movement_type": "immovable"
            },
            "minecraft:connection_rule": {
                "accepts_connections_from": "none"
            },
            "minecraft:light_emission": 2
        },
        "permutations": [
            {
                "condition": "q.block_state('minecraft:multi_block_part') == 1",
                "components": {
                    "minecraft:geometry": {
                        "identifier": "geometry.waystone_top",
                        "culling": "tcsmp:culling.waystone.top"
                    }
                }
            },
            {
                "condition": "q.block_state('tcsmp:active')",
                "components": {
                    "minecraft:material_instances": {
                        "*": {
                            "render_method": "opaque"
                        },
                        "side_top": {
                            "texture": "nether_waystone_side_top_active"
                        },
                        "side_bottom": {
                            "texture": "nether_waystone_side_bottom_active"
                        },
                        "up": {
                            "texture": "nether_waystone_interior"
                        },
                        "down": {
                            "texture": "nether_waystone_exterior"
                        }
                    },
                    "minecraft:light_emission": 10
                }
            }
        ]
    }
