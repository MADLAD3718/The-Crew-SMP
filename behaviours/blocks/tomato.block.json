{
    "format_version": "1.21.70",
    "minecraft:block": {
        "description": {
            "identifier": "tcsmp:tomato",
            "states": {
                "tcsmp:growth_stage": [0, 1, 2]
            }
        },
        "permutations": [
            {
                "condition": "q.block_state('tcsmp:growth_stage') == 0",
                "components": {
                    "minecraft:material_instances": {
                        "*": {
                            "texture": "tomato_stage_0",
                            "render_method": "alpha_test",
                            "face_dimming": false
                        }
                    },
                    "minecraft:selection_box": {
                        "origin": [-3, 0, -3],
                        "size": [6, 7, 6]
                    }
                }
            },
            {
                "condition": "q.block_state('tcsmp:growth_stage') == 1",
                "components": {
                    "minecraft:material_instances": {
                        "*": {
                            "texture": "tomato_stage_1",
                            "render_method": "alpha_test",
                            "face_dimming": false
                        }
                    },
                    "minecraft:selection_box": {
                        "origin": [-4, 0, -4],
                        "size": [8, 10, 8]
                    }
                }
            },
            {
                "condition": "q.block_state('tcsmp:growth_stage') == 2",
                "components": {
                    "minecraft:material_instances": {
                        "*": {
                            "texture": "tomato_stage_2",
                            "render_method": "alpha_test",
                            "face_dimming": false
                        }
                    },
                    "minecraft:selection_box": {
                        "origin": [-5, 0, -5],
                        "size": [10, 14, 10]
                    },
                    "minecraft:loot": "loot_tables/blocks/tomato_grown.json"
                }
            }
        ],
        "components": {
            "minecraft:custom_components": ["tcsmp:crop"],
            "minecraft:map_color": "#6f8b3a",
            "minecraft:collision_box": false,
            "minecraft:geometry": "geometry.cross_crop",
            "minecraft:light_dampening": 0,
            "minecraft:liquid_detection": {
                "detection_rules": [{
                    "liquid_type": "water",
                    "on_liquid_touches": "popped"
                }]
            },
            "minecraft:loot": "loot_tables/blocks/tomato.json",
            "minecraft:placement_filter": {
                "conditions": [{
                    "allowed_faces": ["up"],
                    "block_filter": [{"name": "minecraft:farmland"}]
                }]
            },
            "tag:minecraft:crop": {}
        }
    }
}