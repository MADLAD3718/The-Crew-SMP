            "minecraft:geometry": "geometry.waystone_bottom",
            "minecraft:material_instances": {
                "*": {
                    "render_method": "opaque"
                },
                "side_top": {
                    "texture": "waystone_side_top"
                },
                "side_bottom": {
                    "texture": "waystone_side_bottom"
