                "north": "side_0",
                "south": "side_0",
                "east": "side_1",
                "west": "side_1",
                "side_0": {
                    "texture": "inscription_table_side_0"
                },
                "side_1": {
                    "texture": "inscription_table_side_1"
                },
                "up": {
                    "texture": "inscription_table_top"
                },
                "down": {
                    "texture": "inscription_table_bottom"
                }
            },
            "minecraft:collision_box": {
                "origin": [-8, 0, -8],
                "size": [16, 12, 16]
            },
            "minecraft:selection_box": {
                "origin": [-8, 0, -8],
                "size": [16, 12, 16]
            },
            "minecraft:crafting_table": {
                "crafting_tags": ["inscription_table"],
                "table_name": "container.inscription_table"
            },
            "minecraft:liquid_detection": {
                "detection_rules": [{
                    "liquid_type": "water",
                    "can_contain_liquid": true
                }]
            },
            "minecraft:destructible_by_mining": {
                "seconds_to_destroy": 5
            },
            "minecraft:tags": [
                "minecraft:is_pickaxe_item_destructible"
            ],
            "minecraft:loot": "loot_tables/blocks/inscription_table.json",
            "minecraft:connection_rule": {
                "accepts_connections_from": "none"
            },
            "minecraft:destructible_by_explosion": {
                "explosion_resistance": 1200
            },
            "minecraft:movable": {
                "movement_type": "immovable"
            },
            "minecraft:support": {
                "shape": "fence"
            },
            "minecraft:light_emission": 7
