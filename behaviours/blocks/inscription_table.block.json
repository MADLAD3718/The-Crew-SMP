                "particle": "tcsmp:inscription_rune"
            },
            "minecraft:tick": {
                "interval_range": [20, 20]
            },
            "minecraft:geometry": {
                "identifier": "geometry.inscription_table",
                "culling": "tcsmp:culling.inscription_table"
            },
            "minecraft:material_instances": {
                "*": {
                    "render_method": "opaque"
