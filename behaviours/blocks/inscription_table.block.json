{
    "format_version": "1.26.20",
    "minecraft:block": {
        "description": {
            "identifier": "tcsmp:inscription_table",
            "menu_category": {
                "category": "items"
            },
            "traits": {
                "minecraft:placement_direction": {
                    "enabled_states": ["minecraft:cardinal_direction"]
                }
            }
        },
        "components": {
