                "minecraft:brightness_filter": {
                    "min": 7,
                    "max": 15,
                    "adjust_for_weather": false
                },
                "minecraft:height_filter": {
                    "min": 60,
                    "max": 75
                },
                "minecraft:weight": {
                    "default": 8
                },
                "minecraft:herd": {
                    "min_size": 2,
                    "max_size": 6
                },
                "minecraft:biome_filter": [
                    {"test": "has_biome_tag", "value": "beach" },
                    {"test": "has_biome_tag", "operator": "not", "value": "cold"}
                ]
            }
        ]
    }
}
