{
  "format_version": "1.26.20",
  "minecraft:entity": {
    "description": {
      "identifier": "tcsmp:stair_seat",
      "is_spawnable": false,
      "is_summonable": true
    },
    "component_groups": {
      "tcsmp:rider_test": {
        "minecraft:environment_sensor": {
          "triggers": [{
            "filters": {
              "test": "rider_count",
              "value": 1
            },
            "event": "tcsmp:gain_rider"
          }]
        }
      },
      "tcsmp:ridden": {
        "minecraft:environment_sensor": {
          "triggers": [{
            "filters": {
              "test": "rider_count",
              "value": 0
            },
            "event": "tcsmp:despawn"
          }]
        }
      },
      "tcsmp:instant_despawn": {
        "minecraft:instant_despawn": {}
      }
    },
    "components": {
      "minecraft:type_family": {
        "family": ["technical"]
      },
      "minecraft:collision_box": {
        "height": 0.0,
        "width": 0.0
      },
      "minecraft:custom_hit_test": {
        "hitboxes": [{
          "height": 0.0,
          "width": 0.0,
          "pivot": [0.0, 0.0, 0.0]
        }]
      },
      "minecraft:health": {
        "value": 1,
        "min": 1,
        "max": 1
      },
      "minecraft:physics": {
        "has_collision": false,
        "has_gravity": false
      },
      "minecraft:damage_sensor": {
        "triggers": [
          {
            "cause": "all",
            "deals_damage": "no"
          }
        ]
      },
      "minecraft:rideable": {
        "family_types": ["player"],
        "pull_in_entities": false,
        "crouching_skip_interact": false,
        "rider_can_interact": false,
        "seat_count": 1,
        "seats": [{ "position": [0, 0, 0] }]
      },
      "minecraft:rotation_axis_aligned": {}
    },
    "events": {
      "minecraft:entity_spawned": {
        "add": {
          "component_groups": ["tcsmp:rider_test"]
        }
      },
      "tcsmp:gain_rider": {
        "remove": {
          "component_groups": ["tcsmp:rider_test"]
        },
        "add": {
          "component_groups": ["tcsmp:ridden"]
        }
      },
      "tcsmp:despawn": {
        "remove": {
          "component_groups": ["tcsmp:ridden"]
        },
        "add": {
          "component_groups": ["tcsmp:instant_despawn"]
        }
      }
    }
  }
}