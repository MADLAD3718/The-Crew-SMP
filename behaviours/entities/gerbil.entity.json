{ 
    "format_version": "1.21.70",
    "minecraft:entity": {
        "description": {
            "identifier": "tcsmp:gerbil",
            "is_spawnable": true,
            "is_summonable": true,
            "properties": {
                "tcsmp:cartwheeling": {
                    "type": "bool",
                    "default": false,
                    "client_sync": true
                }
            }
        },
        "component_groups": {
            "tcsmp:baby": {
                "minecraft:is_baby": {},
                "minecraft:scale": {
                    "value": 0.5
                },
                "minecraft:ageable": {
                    "duration": 600,
                    "feed_items": ["tcsmp:tomato"],
                    "grow_up": {
                        "event": "tcsmp:grow_up",
                        "target": "self"
                    }
                },
                "minecraft:behavior.panic": {
                    "priority": 0,
                    "speed_multiplier": 1.25
                },
                "minecraft:behavior.follow_parent": {
                    "priority": 1,
                    "speed_multiplier": 1.25
                }
            },
            "tcsmp:adult": {
                "minecraft:breedable": {
                    "require_tame": true,
                    "require_full_health": true,
                    "breeds_with": {
                        "mate_type": "tcsmp:gerbil",
                        "baby_type": "tcsmp:gerbil",
                        "breed_event": {
                            "event": "minecraft:entity_born",
                            "target": "baby"
                        }
                    },
                    "breed_items": ["tcsmp:tomato"]
                },
                "minecraft:behavior.panic": {
                    "priority": 0,
                    "speed_multiplier": 1.0
                },
                "minecraft:behavior.breed": {
                    "priority": 1,
                    "speed_multiplier": 1
                }
            },
            "tcsmp:wild": {
                "minecraft:behavior.tempt": {
                    "priority": 2,
                    "speed_multiplier": 1.0,
                    "items": ["tcsmp:tomato"]
                },
                "minecraft:despawn": {
                    "despawn_from_distance": {}
                },
                "minecraft:behavior.random_sitting": {
                    "priority": 3,
                    "min_sit_time": 2.0,
                    "start_chance": 0.75,
                    "stop_chance": 0.2
                },
                "minecraft:behavior.random_stroll": {
                    "priority": 4,
                    "speed_multiplier": 1
                }
            },
            "tcsmp:tamed": {
                "minecraft:behavior.follow_owner": {
                    "priority": 2,
                    "can_teleport": false,
                    "start_distance": 3,
                    "stop_distance": 2,
                    "speed_multiplier": 1.25
                },
                "minecraft:interact": {
                    "interactions": [{
                        "on_interact": {
                            "filters": {
                                "all_of": [
                                    {
                                        "test": "is_owner",
                                        "subject": "player"
                                    },
                                    {
                                        "test": "all_slots_empty",
                                        "subject": "player",
                                        "value": "hand"
                                    }
                                ]
                            },
                            "interact_text": "action.interact.gerbil"
                        },
                        "swing": true
                    }]
                }
            },
            "tcsmp:cartwheeling": {
                "minecraft:timer": {
                    "time": 0.5,
                    "time_down_event": {
                        "event": "tcsmp:stop_cartwheel"
                    }
                }
            },
            "tcsmp:idle": {
                "minecraft:timer": {
                    "randomInterval": true,
                    "looping": true,
                    "time": [15, 60],
                    "time_down_event": {
                        "event": "tcsmp:start_cartwheel"
                    }
                }
            }
        },
        "components": {
            "minecraft:type_family": {
                "family": ["mob", "gerbil"]
            },
            "minecraft:physics": {},
            "minecraft:pushable": {
                "is_pushable": true,
                "is_pushable_by_piston": true
            },
            "minecraft:conditional_bandwidth_optimization": {},
            "minecraft:collision_box": {
                "width": 0.25,
                "height": 0.125
            },
            "minecraft:health": {
                "value": 6,
                "max": 6
            },
            "minecraft:is_hidden_when_invisible": {},
            "minecraft:breathable": {
                "total_supply": 15,
                "suffocate_time": 0
            },
            "minecraft:nameable": {},
            "minecraft:tameable": {
                "probability": 1.0,
                "tame_items": "tcsmp:tomato",
                "tame_event": {
                    "event": "tcsmp:on_tame",
                    "target": "self"
                }
            },
            "minecraft:movement": {
                "value": 0.3
            },
            "minecraft:can_climb": {},
            "minecraft:jump.static": {},
            "minecraft:movement.basic": {},
            "minecraft:navigation.walk": {
                "avoid_portals": true,
                "avoid_damage_blocks": true,
                "avoid_water": true,
                "can_path_over_water": false,
                "can_sink": false,
                "can_float": false,
                "can_jump": true,
                "can_climb": true,
                "blocks_to_avoid": [
                    "minecraft:water",
                    "minecraft:flowing_water",
                    "minecraft:dead_brain_coral",
                    "minecraft:dead_brain_coral_block",
                    "minecraft:dead_brain_coral_fan",
                    "minecraft:dead_brain_coral_wall_fan",
                    "minecraft:dead_bubble_coral",
                    "minecraft:dead_bubble_coral_block",
                    "minecraft:dead_bubble_coral_fan",
                    "minecraft:dead_bubble_coral_wall_fan",
                    "minecraft:dead_fire_coral",
                    "minecraft:dead_fire_coral_block",
                    "minecraft:dead_fire_coral_fan",
                    "minecraft:dead_fire_coral_wall_fan",
                    "minecraft:dead_horn_coral",
                    "minecraft:dead_horn_coral_block",
                    "minecraft:dead_horn_coral_fan",
                    "minecraft:dead_horn_coral_wall_fan",
                    "minecraft:dead_tube_coral",
                    "minecraft:dead_tube_coral_block",
                    "minecraft:dead_tube_coral_fan",
                    "minecraft:dead_tube_coral_wall_fan",
                    "minecraft:brain_coral",
                    "minecraft:brain_coral_block",
                    "minecraft:brain_coral_fan",
                    "minecraft:brain_coral_wall_fan",
                    "minecraft:bubble_coral",
                    "minecraft:bubble_coral_block",
                    "minecraft:bubble_coral_fan",
                    "minecraft:bubble_coral_wall_fan",
                    "minecraft:fire_coral",
                    "minecraft:fire_coral_block",
                    "minecraft:fire_coral_fan",
                    "minecraft:fire_coral_wall_fan",
                    "minecraft:horn_coral",
                    "minecraft:horn_coral_block",
                    "minecraft:horn_coral_fan",
                    "minecraft:horn_coral_wall_fan",
                    "minecraft:tube_coral",
                    "minecraft:tube_coral_block",
                    "minecraft:tube_coral_fan",
                    "minecraft:tube_coral_wall_fan",
                    "minecraft:seagrass",
                    "minecraft:sea_pickle",
                    "minecraft:kelp"
                ]
            },
            "minecraft:vibration_damper": {},
            "minecraft:hurt_on_condition": {
                "damage_conditions": [{
                    "filters": {
                        "test": "in_lava",
                        "subject": "self",
                        "operator": "==",
                        "value": true
                    },
                    "cause": "lava",
                    "damage_per_tick": 4
                }]
            }
        },
        "events": {
            "minecraft:entity_spawned": {
                "trigger": "tcsmp:spawn_wild_baby_or_adult"
            },
            "minecraft:entity_born": {
                "trigger": "tcsmp:spawn_tame_baby"
            },
            "tcsmp:spawn_wild_baby_or_adult": {
                "sequence": [
                    {
                        "randomize": [
                            {
                                "weight": 9,
                                "trigger": "tcsmp:spawn_wild_adult"
                            },
                            {
                                "weight": 1,
                                "trigger": "tcsmp:spawn_wild_baby"
                            }
                        ]
                    }
                ]
            },
            "tcsmp:spawn_wild_adult": {
                "add": {
                    "component_groups": [
                        "tcsmp:wild",
                        "tcsmp:idle",
                        "tcsmp:adult"
                    ]
                }
            },
            "tcsmp:spawn_wild_baby": {
                "add": {
                    "component_groups": [
                        "tcsmp:wild",
                        "tcsmp:idle",
                        "tcsmp:baby"
                    ]
                }
            },
            "tcsmp:spawn_tame_baby": {
                "remove": {
                    "component_groups": ["tcsmp:wild"]
                },
                "add": {
                    "component_groups": [
                        "tcsmp:baby",
                        "tcsmp:tamed"
                    ]
                }
            },
            "tcsmp:grow_up": {
                "remove": {
                    "component_groups": ["tcsmp:baby"]
                },
                "add": {
                    "component_groups": ["tcsmp:adult"]
                }
            },
            "tcsmp:on_tame": {
                "remove": {
                    "component_groups": ["tcsmp:wild"]
                },
                "add": {
                    "component_groups": ["tcsmp:tamed"]
                }
            },
            "tcsmp:start_cartwheel": {
                "add": {
                    "component_groups": ["tcsmp:cartwheeling"]
                },
                "remove": {
                    "component_groups": ["tcsmp:idle"]
                },
                "set_property": {
                    "tcsmp:cartwheeling": true
                }
            },
            "tcsmp:stop_cartwheel": {
                "add": {
                    "component_groups": ["tcsmp:idle"]
                },
                "remove": {
                    "component_groups": ["tcsmp:cartwheeling"]
                },
                "set_property": {
                    "tcsmp:cartwheeling": false
                }
            }
        }
    }
}
