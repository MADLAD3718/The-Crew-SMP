{
  "format_version": "1.26.20",
  "minecraft:entity": {
    "description": {
      "identifier": "tcsmp:unicorn",
      "spawn_category": "creature",
      "is_spawnable": true,
      "is_summonable": true
    },

    "component_groups": {
      "tcsmp:unicorn_baby": {
        "minecraft:is_baby": {
        },
        "minecraft:scale_by_age": {
          "start_scale": 0.5,
          "end_scale": 1.0
        },
        "minecraft:ageable": {
          "duration": 1200,
          "feed_items": [
            {
              "item": "glistering_melon_slice",
              "growth": 0.05
            },
            {
              "item": "golden_carrot",
              "growth": 0.05
            },
            {
              "item": "golden_apple",
              "growth": 0.2
            },
            {
              "item": "enchanted_golden_apple",
              "growth": 0.2
            }
          ],
          "pause_growth_items": [ "golden_dandelion" ],
          "reset_growth_items": [ "golden_dandelion" ],
          "grow_up": {
            "event": "tcsmp:ageable_grow_up",
            "target": "self"
          }
        },
        "minecraft:behavior.follow_parent": {
          "priority": 4,
          "speed_multiplier": 1.0
        }
      },

      "tcsmp:unicorn_adult": {
        "minecraft:experience_reward": {
          "on_bred": "Math.Random(1,7)",
          "on_death": "query.last_hit_by_player ? Math.Random(1,3) : 0"
        },
        "minecraft:loot": {
          "table": "loot_tables/entities/horse.json"
        },
        "minecraft:behavior.run_around_like_crazy": {
          "priority": 1,
          "speed_multiplier": 1.2
        },
        "minecraft:behavior.breed": {
          "priority": 2,
          "speed_multiplier": 1.0
        },
        "minecraft:leashable_to": {},
        "minecraft:offspring": {
          "offspring_pairs": {
            "tcsmp:unicorn": "tcsmp:unicorn"
          }
        },
        "minecraft:spawn_egg_interaction": {}
      },

      "tcsmp:unicorn_wild": {
        "minecraft:rideable": {
          "seat_count": 1,
          "family_types": [
            "player",
            "zombie"
          ],
          "interact_text": "action.interact.mount",
          "seats": {
            "position": [ 0.0, 1.1, -0.2 ]
          }
        },
        "minecraft:behavior.mount_pathing": {
          "priority": 2,
          "speed_multiplier": 1.5,
          "target_dist": 0.0,
          "track_target": true
        },
        "minecraft:environment_sensor": {
          "triggers": {
            "filters": {
              "test": "rider_count",
              "value": 1
            },
            "event": "tcsmp:ride_wild"
          }
        }
      },

      "tcsmp:riding_wild": {
        "minecraft:environment_sensor": {
          "triggers": {
            "filters": {
              "test": "rider_count",
              "value": 0
            },
            "event": "tcsmp:rider_kicked"
          }
        }
      },

      "tcsmp:unicorn_tamed": {
        "minecraft:is_tamed": {},
        "minecraft:rideable": {
          "seat_count": 1,
          "crouching_skip_interact": true,
          "family_types": [
            "player"
          ],
          "interact_text": "action.interact.ride.tcsmp:unicorn",
          "seats": {
            "position": [ 0.0, 1.1, -0.2 ]
          }

        },
        "minecraft:interact": {
          "interactions": [
            {
              "on_interact": {
                "filters": {
                  "all_of": [
                    {
                      "test": "has_equipment",
                      "subject": "self",
                      "domain": "inventory",
                      "operator": "not",
                      "value": "saddle"
                    },
                    {
                      "test": "has_equipment",
                      "subject": "other",
                      "domain": "hand",
                      "value": "saddle"
                    },
                    {
                      "test": "is_sneak_held",
                      "subject": "other",
                      "value": false
                    }
                  ]
                },
                "target": "self"
              },
              "equip_item_slot": "0",
              "interact_text": "action.interact.saddle",
              "play_sounds": "saddle"
            },
            {
              "on_interact": {
                "filters": {
                  "all_of": [
                    {
                      "test": "rider_count",
                      "subject": "self",
                      "operator": "equals",
                      "value": 0
                    },
                    {
                      "test": "has_equipment",
                      "subject": "self",
                      "domain": "inventory",
                      "value": "saddle"
                    },
                    {
                      "test": "has_equipment",
                      "subject": "other",
                      "domain": "hand",
                      "value": "shears"
                    },
                    {
                      "test": "is_sneak_held",
                      "subject": "other",
                      "value": false
                    }
                  ]
                }
              },
              "hurt_item": 1,
              "drop_item_slot": "0",
              "drop_item_y_offset": 1.1,
              "interact_text": "action.interact.removesaddle",
              "play_sounds": "unsaddle",
              "vibration": "shear"
            }
          ]
        },
        "minecraft:inventory": {
          "inventory_size": 1,
          "container_type": "horse"
        },
        "minecraft:breedable": {
          "require_tame": true,
          "breeds_with": {
            "tcsmp:unicorn": {}
          },
          "breed_items": [
            "golden_carrot",
            "golden_apple",
            "enchanted_golden_apple"
          ]
        },
        "minecraft:offspring": {
          "inherit_tamed": false,
          "offspring_pairs": {
            "tcsmp:unicorn": "tcsmp:unicorn"
          }
        }
      },

      "tcsmp:unicorn_saddled": {
        "minecraft:is_saddled": {
        },
        "minecraft:input_ground_controlled": {
        },
        "minecraft:can_power_jump": {
        },
        "minecraft:behavior.player_ride_tamed": {
        }
      }
    },

    "components": {
      "minecraft:is_hidden_when_invisible": {},
      "minecraft:ambient_sound_interval": {},
      "minecraft:equippable": {
        "slots": [
          {
            "slot": 0,
            "item": "saddle",
            "accepted_items": [ "saddle" ],
            "on_equip": {
              "event": "tcsmp:unicorn_saddled"
            },
            "on_unequip": {
              "event": "tcsmp:unicorn_unsaddled"
            }
          }
        ]
      },
      "minecraft:type_family": {
        "family": [ "horse", "unicorn", "mob" ]
      },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0
      },
      "minecraft:collision_box": {
        "width": 1.4,
        "height": 1.6
      },
      "minecraft:health": {
        "value": 40
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": {
              "test": "in_lava",
              "subject": "self",
              "operator": "==",
              "value": true
            },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      "minecraft:movement": {
        "value": 0.3375
      },
      "minecraft:damage_sensor": {
        "triggers": [{
          "cause": "fall",
          "deals_damage": "no"
        }]
      },
      "minecraft:navigation.walk": {
        "can_path_over_water": true,
        "avoid_water": true,
        "avoid_damage_blocks": true
      },
      "minecraft:movement.basic": {
        "max_turn": 60
      },
      "minecraft:jump.static": {},
      "minecraft:nameable": {},
      "minecraft:horse.jump_strength": {
        "value": 1.0
      },
      "minecraft:variable_max_auto_step": {
        "base_value": 1.0,
        "controlled_value": 1.0,
        "jump_prevented_value": 0.0
      },
      "minecraft:leashable": {
        "presets": [
          {
            "filter": {
              "test": "is_family",
              "subject": "other",
              "value": "happy_ghast"
            },
            "spring_type": "quad_dampened"
          }
        ]
      },
      "minecraft:balloonable": {},
      "minecraft:healable": {
        "items": [
          {
            "item": "glistering_melon_slice",
            "heal_amount": 4
          },
          {
            "item": "golden_carrot",
            "heal_amount": 4
          },
          {
            "item": "golden_apple",
            "heal_amount": 10
          },
          {
            "item": "enchanted_golden_apple",
            "heal_amount": 10
          }
        ]
      },
      "minecraft:despawn": {
        "despawn_from_distance": {}
      },
      "minecraft:behavior.float": {
        "priority": 0,
        "sink_with_passengers": true
      },
      "minecraft:behavior.panic": {
        "priority": 3,
        "speed_multiplier": 1.2
      },
      "minecraft:behavior.tempt": {
        "priority": 5,
        "speed_multiplier": 1.2,
        "items": [
          "golden_apple",
          "enchanted_golden_apple",
          "golden_carrot"
        ]
      },
      "minecraft:tamemount": {
        "min_temper": 0,
        "max_temper": 100,
        "feed_text": "action.interact.feed",
        "ride_text": "action.interact.mount",
        "feed_items": [
          {
            "item": "glistering_melon_slice",
            "temper_mod": 5
          },
          {
            "item": "golden_carrot",
            "temper_mod": 5
          },
          {
            "item": "golden_apple",
            "temper_mod": 10
          },
          {
            "item": "enchanted_golden_apple",
            "temper_mod": 10
          }
        ],
        "auto_reject_items": [
          {
            "item": "saddle"
          }
        ],
        "tame_event": {
          "event": "tcsmp:on_tame",
          "target": "self"
        }
      },
      "minecraft:behavior.random_stroll": {
        "priority": 6,
        "speed_multiplier": 0.7
      },
      "minecraft:behavior.look_at_player": {
        "priority": 7,
        "look_distance": 6.0,
        "probability": 0.02
      },
      "minecraft:behavior.random_look_around": {
        "priority": 8
      },
      "minecraft:physics": {},
      "minecraft:pushable_by_block": {},
      "minecraft:pushable_by_entity": {}
    },

    "events": {
      "minecraft:entity_spawned": {
        "sequence": [
          {
            "randomize": [
              {
                "weight": 36,
                "add": {
                  "component_groups": [
                    "tcsmp:unicorn_adult",
                    "tcsmp:unicorn_wild"
                  ]
                }
              },
              {
                "weight": 9,
                "add": {
                  "component_groups": [
                    "tcsmp:unicorn_baby"
                  ]
                }
              }
            ]
          }
        ]
      },

      "minecraft:entity_born": {
        "add": {
          "component_groups": [
            "tcsmp:unicorn_baby"
          ]
        }
      },

      "minecraft:spawn_adult": {
        "add": {
          "component_groups": [
            "tcsmp:unicorn_adult",
            "tcsmp:unicorn_wild"
          ]
        }
      },

      "minecraft:spawn_tame_adult": {
        "add": {
          "component_groups": [
            "tcsmp:unicorn_adult",
            "tcsmp:unicorn_tamed"
          ]
        }
      },

      "tcsmp:on_tame": {
        "remove": {
          "component_groups": [
            "tcsmp:unicorn_wild",
            "tcsmp:riding_wild"
          ]
        },
        "add": {
          "component_groups": [
            "tcsmp:unicorn_tamed"
          ]
        }
      },

      "tcsmp:ageable_grow_up": {
        "remove": {
          "component_groups": [
            "tcsmp:unicorn_baby"
          ]
        },
        "add": {
          "component_groups": [
            "tcsmp:unicorn_adult",
            "tcsmp:unicorn_wild"
          ]
        }
      },

      "tcsmp:unicorn_saddled": {
        "add": {
          "component_groups": [
            "tcsmp:unicorn_saddled"
          ]
        }
      },

      "tcsmp:unicorn_unsaddled": {
        "remove": {
          "component_groups": [
            "tcsmp:unicorn_saddled"
          ]
        }
      },

      "tcsmp:ride_wild": {
        "add": {
          "component_groups": ["tcsmp:riding_wild"]
        }
      },

      "tcsmp:rider_kicked": {
        "play_sound": {
          "sound": "mad"
        },
        "remove": {
          "component_groups": ["tcsmp:riding_wild"]
        }
      }
    }
  }
}
