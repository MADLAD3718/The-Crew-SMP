{
  "format_version": "1.21.70",
  "minecraft:entity": {
    "description": {
      "identifier": "tcsmp:seal",
      "spawn_category": "water_creature",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false,
      "properties": {
        "tcsmp:ridden": {
          "type": "bool",
          "client_sync": false,
          "default": false
        }
      }
    },
    "component_groups": {
      "tcsmp:baby": {
        "minecraft:is_baby": {},
        "minecraft:ageable": {
          "duration": 1200,
          "feed_items": [
            "minecraft:cod",
            "minecraft:salmon"
          ],
          "grow_up": {
            "event": "tcsmp:grow_up",
            "target": "self"
          }
        },
        "minecraft:behavior.follow_parent": {
          "priority": 0,
          "speed_multiplier": 1.1
        },
        "minecraft:scale": {
          "value": 0.75
        }
      },
      "tcsmp:adult": {
        "minecraft:experience_reward": {
          "on_bred": "Math.Random(1,7)",
          "on_death": "query.last_hit_by_player ? Math.Random(1,3) : 0"
        },
        "minecraft:scale": {
          "value": 1.2
        },
        "minecraft:behavior.breed": {
          "priority": 1,
          "speed_multiplier": 1.0
        },
        "minecraft:breedable": {
          "require_tame": false,
          "inherit_tamed": false,
          "breeds_with": [
            {
              "mate_type": "tcsmp:seal",
              "baby_type": "tcsmp:seal",
              "breed_event": {
                "event": "minecraft:entity_born",
                "target": "baby"
              }
            }
          ],
          "breed_items": [
            "minecraft:cod",
            "minecraft:salmon"
          ]
        },
        "minecraft:spawn_egg_interaction": {}
      },
      "tcsmp:unmounted_movement": {
        "minecraft:underwater_movement": {
          "value": 0.19
        },
        "minecraft:behavior.panic": {
          "priority": 0,
          "prefer_water": true,
          "speed_multiplier": 1.1
        }
      },
      "tcsmp:mounted_movement": {
        "minecraft:underwater_movement": {
          "value": 0.075
        }
      },
      "tcsmp:rideable": {
        "minecraft:rideable": {
          "family_types": ["player"],
          "interact_text": "action.interact.ride.seal",
          "seats": [{
            "position": [0, -0.15, 0.4]
          }]
        },
        "minecraft:input_ground_controlled": {}
      },
      "tcsmp:in_water": {
        "minecraft:timer": {
          "looping": false,
          "randomInterval": true,
          "time": [20, 40],
          "time_down_event": {
            "event": "tcsmp:become_tired"
          }
        },
        "minecraft:behavior.nearest_attackable_target": {
          "priority": 4,
          "must_see": true,
          "reselect_targets": true,
          "within_radius": 20.0,
          "must_see_forget_duration": 17.0,
          "entity_types": [
            {
              "filters": {
                "all_of": [
                  { "test": "in_water", "subject": "other", "value": true },
                  { "test": "has_component", "subject": "self", "operator": "!=", "value": "minecraft:attack_cooldown" },
                  { "test": "is_family", "subject": "other", "value": "fish" }
                ]
              },
              "max_dist": 8
            }
          ]
        },
        "minecraft:behavior.melee_box_attack": {
          "priority": 5,
          "on_kill": {
            "event": "tcsmp:stop_hunting"
          }
        },
        "minecraft:environment_sensor": {
          "triggers": [
            {
              "filters": {
                "test": "in_water",
                "value": false
              },
              "event": "tcsmp:surface"
            },
            {
              "filters": {
                "all_of": [
                  {
                    "test": "rider_count",
                    "value": 1
                  },
                  {
                    "test": "bool_property",
                    "domain": "tcsmp:ridden",
                    "value": false
                  }
                ]
              },
              "event": "tcsmp:mounted"
            },
            {
              "filters": {
                "all_of": [
                  {
                    "test": "rider_count",
                    "value": 0
                  },
                  {
                    "test": "bool_property",
                    "domain": "tcsmp:ridden",
                    "value": true
                  }
                ]
              },
              "event": "tcsmp:dismounted"
            }
          ]
        }
      },
      "tcsmp:tired": {
        "minecraft:behavior.move_to_land": {
          "priority": 4,
          "search_count": 80,
          "search_height": 20,
          "search_range": 30,
          "goal_radius": 0.1
        }
      },
      "tcsmp:attack_cooldown": {
        "minecraft:attack_cooldown": {
          "attack_cooldown_time": 30.0,
          "attack_cooldown_complete_event": {
            "event": "tcsmp:go_hunting"
          }
        }
      },
      "tcsmp:in_air": {
        "minecraft:timer": {
          "looping": false,
          "randomInterval": true,
          "time": [3, 5],
          "time_down_event": {
            "event": "tcsmp:go_to_sleep"
          }
        },
        "minecraft:behavior.look_at_player": {
          "priority": 6,
          "angle_of_view_horizontal": 30,
          "angle_of_view_vertical": 25,
          "min_look_time": 1,
          "max_look_time": 5,
          "probability": 1.0
        },
        "minecraft:environment_sensor": {
          "triggers": [{
            "filters": {
              "test": "in_water",
              "value": true
            },
            "event": "tcsmp:submerge"
          }]
        }
      },
      "tcsmp:strolling": {
        "minecraft:behavior.random_stroll": {
          "priority": 5,
          "interval": 1
        }
      },
      "tcsmp:sleepy": {
        "minecraft:sittable": {},
        "minecraft:behavior.random_look_around_and_sit": {
          "priority": 3,
          "continue_sitting_on_reload": true,
          "min_angle_of_view_horizontal": 0,
          "max_angle_of_view_horizontal": 0,
          "max_look_count": 1,
          "min_look_count": 1,
          "min_look_time": 400,
          "max_look_time": 700,
          "probability": 1.0,
          "random_look_around_cooldown": 60
        },
        "minecraft:behavior.move_to_water": {
          "priority": 4,
          "search_count": 80,
          "search_height": 20,
          "search_range": 30,
          "goal_radius": 0.1
        },
        "minecraft:damage_sensor": {
          "triggers": [{
            "cause": "all",
            "on_damage": {
              "filters": {
                "test": "is_sitting"
              },
              "event": "tcsmp:force_awake"
            }
          }]
        },
        "minecraft:environment_sensor": {
          "triggers": [
            {
              "filters": {
                "all_of": [
                  { "test": "is_sitting" },
                  { "test": "in_water", "value": false },
                  { "test": "in_water_or_rain" }
                ]
              },
              "event": "tcsmp:force_awake"
            },
            {
              "filters": {
                "test": "in_water",
                "value": true
              },
              "event": "tcsmp:submerge"
            }
          ]
        },
        "minecraft:entity_sensor": {
          "find_players_only": true,
          "subsensors": [{
            "event": "tcsmp:force_awake",
            "cooldown": 0.2,
            "range": [ 3.5, 2.0 ],
            "minimum_count": 1,
            "event_filters": {
              "any_of": [
                { "test": "is_sprinting", "subject": "other" },
                { "test": "is_riding", "subject": "other" }
              ]
            }
          }]
        }
      },
      "tcsmp:retreating": {
        "minecraft:behavior.move_to_water": {
          "priority": 4,
          "search_count": 80,
          "search_height": 20,
          "search_range": 30,
          "goal_radius": 0.1
        },
        "minecraft:environment_sensor": {
          "triggers": [{
            "filters": {
              "test": "in_water",
              "value": true
            },
            "event": "tcsmp:submerge"
          }]
        }
      }
    },
    "components": {
      "minecraft:is_hidden_when_invisible": {},
      "minecraft:type_family": {
        "family": [
          "aquatic",
          "seal",
          "mob"
        ]
      },
      "minecraft:collision_box": {
        "width": 1.0,
        "height": 0.6
      },
      "minecraft:health": {
        "value": 14,
        "max": 14
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": {
              "test": "in_lava",
              "subject": "self",
              "operator": "==",
              "value": true
            },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      "minecraft:loot": {
        "table": "loot_tables/entities/seal.json"
      },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0,
        "breathes_water": true,
        "breathes_air": true,
        "generates_bubbles": false
      },
      "minecraft:can_climb": {},
      "minecraft:despawn": {
        "despawn_from_distance": {
          "min_distance": 32,
          "max_distance": 40
        }
      },
      "minecraft:nameable": {},
      "minecraft:physics": {},
      "minecraft:pushable": {
        "is_pushable": true,
        "is_pushable_by_piston": true
      },
      "minecraft:leashable": {
        "soft_distance": 4.0,
        "hard_distance": 6.0,
        "max_distance": 10.0
      },
      "minecraft:conditional_bandwidth_optimization": {},
      "minecraft:navigation.generic": {
        "is_amphibious": true,
        "can_path_over_water": true,
        "can_swim": true,
        "can_walk": true,
        "can_sink": false,
        "can_breach": true,
        "can_path_from_air": true
      },
      "minecraft:movement.amphibious": {
        "max_turn": 15.0
      },
      "minecraft:movement": {
        "value": 0.3
      },
      "minecraft:jump.static": {
        "jump_power": 0.48
      },
      "minecraft:attack": {
        "damage": 2
      },
      "minecraft:combat_regeneration": {
        "apply_to_family": true,
        "apply_to_self": true,
        "regeneration_duration": 5
      },
      "minecraft:home": {
        "home_block_list": [
          "minecraft:sand",
          "minecraft:ice"
        ],
        "restriction_radius": 24,
        "restriction_type": "all_movement"
      },
      "minecraft:behavior.tempt": {
        "priority": 2,
        "speed_multiplier": 1.1,
        "can_tempt_vertically": true,
        "items": [
          "minecraft:cod",
          "minecraft:salmon"
        ]
      },
      "minecraft:behavior.beg": {
        "priority": 2,
        "look_distance": 8,
        "look_time": [ 2, 4 ],
        "items": [
          "minecraft:cod",
          "minecraft:salmon"
        ]
      },
      "minecraft:behavior.move_towards_home_restriction": {
        "priority": 3
      }
    },
    "events": {
      "minecraft:entity_spawned": {
        "sequence": [
          {
            "add": {
              "component_groups": [
                "tcsmp:in_air",
                "tcsmp:strolling",
                "tcsmp:unmounted_movement"
              ]
            }
          },
          {
            "randomize": [
              {
                "weight": 9,
                "add": {
                  "component_groups": ["tcsmp:adult"]
                }
              },
              {
                "weight": 1,
                "add": {
                  "component_groups": ["tcsmp:baby"]
                }
              }
            ]
          }
        ]
      },
      "minecraft:entity_born": {
        "add": {
          "component_groups": [
            "tcsmp:in_air",
            "tcsmp:baby",
            "tcsmp:strolling",
            "tcsmp:unmounted_movement"
          ]
        }
      },
      "tcsmp:submerge": {
        "sequence": [
          {
            "filters": {
              "test": "is_baby",
              "value": false
            },
            "add": {
              "component_groups": ["tcsmp:rideable"]
            }
          },
          {
            "remove": {
              "component_groups": [
                "tcsmp:in_air",
                "tcsmp:sleepy",
                "tcsmp:retreating",
                "tcsmp:tired"
              ]
            },
            "add": {
              "component_groups": [
                "tcsmp:in_water",
                "tcsmp:strolling"
              ]
            },
            "set_property": {
              "tcsmp:ridden": false
            }
          }
        ]
      },
      "tcsmp:surface": {
        "remove": {
          "component_groups": [
            "tcsmp:in_water",
            "tcsmp:rideable",
            "tcsmp:mounted_movement"
          ]
        },
        "add": {
          "component_groups": [
            "tcsmp:in_air",
            "tcsmp:strolling",
            "tcsmp:unmounted_movement"
          ]
        },
        "set_property": {
          "tcsmp:ridden": false
        }
      },
      "tcsmp:stop_hunting": {
        "add": {
          "component_groups": ["tcsmp:attack_cooldown"]
        }
      },
      "tcsmp:go_hunting": {
        "remove": {
          "component_groups": ["tcsmp:attack_cooldown"]
        }
      },
      "tcsmp:go_to_sleep": {
        "add": {
          "component_groups": ["tcsmp:sleepy"]
        },
        "remove": {
          "component_groups": ["tcsmp:strolling"]
        }
      },
      "tcsmp:force_awake": {
        "remove": {
          "component_groups": ["tcsmp:sleepy"]
        },
        "add": {
          "component_groups": ["tcsmp:retreating"]
        }
      },
      "tcsmp:become_tired": {
        "add": {
          "component_groups": ["tcsmp:tired"]
        }
      },
      "tcsmp:mounted": {
        "remove": {
          "component_groups": [
            "tcsmp:strolling",
            "tcsmp:unmounted_movement"
          ]
        },
        "add": {
          "component_groups": ["tcsmp:mounted_movement"]
        },
        "set_property": {
          "tcsmp:ridden": true
        }
      },
      "tcsmp:dismounted": {
        "sequence": [
          {
            "filters": { "test": "in_water" },
            "trigger": "tcsmp:become_tired"
          },
          {
            "remove": {
              "component_groups": ["tcsmp:mounted_movement"]
            },
            "add": {
              "component_groups": [
                "tcsmp:strolling",
                "tcsmp:unmounted_movement"
              ]
            },
            "set_property": {
              "tcsmp:ridden": false
            }
          }
        ]
      }
    }
  }
}