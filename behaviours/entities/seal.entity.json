{
  "format_version": "1.26.30",
  "minecraft:entity": {
    "description": {
      "identifier": "tcsmp:seal",
      "spawn_category": "creature",
      "is_spawnable": true,
      "is_summonable": true,
      "properties": {
        "tcsmp:seal_state": {
          "type": "enum",
          "values": ["strolling", "returning", "hunting", "tired", "sleeping"],
          "default": "returning",
          "client_sync": true
        }
      }
    },
    "component_groups": {
      "tcsmp:baby": {
        "minecraft:is_baby": {},
        "minecraft:ageable": {
          "duration": 1200,
          "feed_items": [
            "minecraft:cod",
            "minecraft:salmon",
            "minecraft:tropical_fish"
          ],
          "grow_up": {
            "event": "tcsmp:grow_up"
          }
        },
        "minecraft:behavior.follow_parent": {
          "priority": 0,
          "speed_multiplier": 1.1
        },
        "minecraft:scale": {
          "value": 0.75
        }
      },
      "tcsmp:adult": {
        "minecraft:experience_reward": {
          "on_bred": "Math.Random(1,7)",
          "on_death": "query.last_hit_by_player ? Math.Random(1,3) : 0"
        },
        "minecraft:scale": {
          "value": 1.2
        },
        "minecraft:spawn_egg_interaction": {}
      },
      "tcsmp:strolling": {
        "minecraft:timer": {
          "looping": false,
          "time": [10, 15],
          "time_down_event": {
            "event": "tcsmp:start_returning"
          }
        },
        "minecraft:breedable": {
          "breed_items": [
            "minecraft:cod",
            "minecraft:salmon",
            "minecraft:tropical_fish"
          ],
          "breeds_with": {
            "tcsmp:seal": {}
          }
        },
        "minecraft:behavior.breed": {
          "priority": 0,
          "speed_multiplier": 1.0
        },
        "minecraft:behavior.tempt": {
          "priority": 1,
          "speed_multiplier": 1.1,
          "can_tempt_vertically": true,
          "items": [
            "minecraft:cod",
            "minecraft:salmon",
            "minecraft:tropical_fish"
          ]
        },
        "minecraft:behavior.beg": {
          "priority": 2,
          "control_flags": ["look", "move", "jump"],
          "items": [
            "minecraft:cod",
            "minecraft:salmon",
            "minecraft:tropical_fish"
          ]
        },
        "minecraft:behavior.random_look_around": {
          "priority": 3
        },
        "minecraft:behavior.random_stroll": {
          "priority": 4,
          "speed_multiplier": 1
        }
      },
      "tcsmp:hunting": {
        "minecraft:timer": {
          "looping": false,
          "time": [50, 60],
          "time_down_event": {
            "event": "tcsmp:tire_out"
          }
        },
        "minecraft:behavior.melee_box_attack": {
          "priority": 1,
          "control_flags": ["look"],
          "track_target": true,
          "on_kill": {
            "event": "tcsmp:on_kill"
          }
        },
        "minecraft:behavior.nearest_attackable_target": {
          "priority": 2,
          "control_flags": ["look", "move", "jump"],
          "must_reach": true,
          "must_see": true,
          "reselect_targets": true,
          "entity_types": [
            {
              "filters": {
                "test": "is_family",
                "subject": "other",
                "value": "fish"
              }
            }
          ]
        },
        "minecraft:behavior.random_swim": {
          "priority": 3,
          "speed_multiplier": 1.5,
          "xz_dist": 16,
          "y_dist": 4,
          "interval": 0
        },
        "minecraft:behavior.swim_wander": {
          "priority": 4,
          "interval": 10,
          "look_ahead": 2.0,
          "speed_multiplier": 1.5,
          "wander_time": 5.0
        },
        "minecraft:behavior.swim_idle": {
          "priority": 5,
          "idle_time": 5,
          "success_rate": 0.1
        }
      },
      "tcsmp:tired": {
        "minecraft:behavior.move_to_land": {
          "priority": 1,
          "control_flags": ["look", "move", "jump"],
          "search_count": 256,
          "search_height": 32,
          "search_range": 32
        },
        "minecraft:behavior.move_towards_home_restriction": {
          "priority": 3,
          "control_flags": ["look", "move", "jump"]
        },
        "minecraft:environment_sensor": {
          "triggers": {
            "filters": {
              "all_of": [
                {
                  "test": "home_distance",
                  "operator": "<=",
                  "value": 5
                },
                {
                  "test": "in_water",
                  "value": false
                }
              ]
            },
            "event": "tcsmp:on_return_home"
          }
        }
      },
      "tcsmp:sleeping": {
        // Disables ambient sounds while sleeping
        "minecraft:ambient_sound_interval": {
          "event_name": ""
        },
        "minecraft:timer": {
          "looping": false,
          "time": [30, 60],
          "time_down_event": {
            "event": "tcsmp:wake_up"
          }
        },
        "minecraft:damage_sensor": {
          "triggers": {
            "cause": "all",
            "deals_damage": "yes",
            "on_damage": {
              "event": "tcsmp:wake_up"
            }
          }
        },
        "minecraft:entity_sensor": {
          "find_players_only": true,
          "relative_range": true,
          "subsensors": [{
            "range": [3.5, 2.0],
            "event_filters": {
              "any_of": [
                {
                  "test": "is_sprinting",
                  "subject": "other"
                },
                {
                  "test": "is_riding",
                  "subject": "other"
                }
              ]
            },
            "event": "tcsmp:wake_up"
          }]
        }
      },
      "tcsmp:returning": {
        "minecraft:behavior.move_to_water": {
          "priority": 1,
          "control_flags": ["jump", "look", "move"],
          "search_count": 128,
          "search_height": 16,
          "search_range": 32
        },
        "minecraft:environment_sensor": {
          "triggers": {
            "filters": {
              "test": "in_water"
            },
            "event": "tcsmp:on_enter_water"
          }
        }
      }
    },
    "components": {
      "minecraft:is_hidden_when_invisible": {},
      "minecraft:type_family": {
        "family": [
          "aquatic",
          "seal",
          "mob"
        ]
      },
      "minecraft:collision_box": {
        "width": 1.0,
        "height": 0.6
      },
      "minecraft:health": {
        "value": 14,
        "max": 14
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": {
              "test": "in_lava",
              "subject": "self",
              "operator": "==",
              "value": true
            },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      "minecraft:loot": {
        "table": "loot_tables/entities/seal.json"
      },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0,
        "breathes_water": true,
        "breathes_air": true,
        "generates_bubbles": false
      },
      "minecraft:can_climb": {},
      "minecraft:despawn": {
        "despawn_from_distance": {
          "min_distance": 32,
          "max_distance": 40
        }
      },
      "minecraft:nameable": {},
      "minecraft:physics": {},
      "minecraft:pushable_by_block": {},
      "minecraft:pushable_by_entity": {},
      "minecraft:leashable": {},
      "minecraft:conditional_bandwidth_optimization": {},
      "minecraft:navigation.generic": {
        "is_amphibious": true,
        "can_path_over_water": true,
        "can_swim": true,
        "can_walk": true,
        "can_sink": false,
        "can_breach": true,
        "can_path_from_air": true
      },
      "minecraft:movement.generic": {
        "max_turn": 15.0
      },
      "minecraft:movement": {
        "value": 0.3
      },
      "minecraft:underwater_movement": {
        "value": 0.17
      },
      "minecraft:jump.static": {
        "jump_power": 0.48
      },
      "minecraft:attack": {
        "damage": 2
      },
      "minecraft:combat_regeneration": {
        "apply_to_family": true,
        "apply_to_self": true,
        "regeneration_duration": 5
      },
      "minecraft:home": {
        "restriction_radius": 5,
        "restriction_type": "random_movement"
      },
      "minecraft:follow_range": {
        "value": 32
      },
      "minecraft:offspring": {
        "offspring_pairs": {
          "tcsmp:seal": "tscmp:seal"
        }
      }
    },
    "events": {
      "minecraft:entity_spawned": {
        "randomize": [
          {
            "weight": 9,
            "add": {
              "component_groups": [
                "tcsmp:adult",
                "tcsmp:returning"
              ]
            }
          },
          {
            "weight": 1,
            "add": {
              "component_groups": ["tcsmp:baby"]
            }
          }
        ],
        "set_home_position": {}
      },
      "tcsmp:grow_up": {
        "remove": {
          "component_groups": ["tcsmp:baby"]
        },
        "add": {
          "component_groups": [
            "tcsmp:adult",
            "tcsmp:returning"
          ]
        }
      },
      "tcsmp:on_enter_water": {
        "trigger": "tcsmp:start_hunting"
      },
      "tcsmp:start_hunting": {
        "remove": {
          "component_groups": [
            "tcsmp:returning",
            "tcsmp:sleeping"
          ]
        },
        "add": {
          "component_groups": ["tcsmp:hunting"]
        },
        "set_property": {
          "tcsmp:seal_state": "hunting"
        }
      },
      "tcsmp:on_kill": {
        "trigger": "tcsmp:tire_out"
      },
      "tcsmp:tire_out": {
        "remove": {
          "component_groups": ["tcsmp:hunting"]
        },
        "add": {
          "component_groups": ["tcsmp:tired"]
        },
        "set_property": {
          "tcsmp:seal_state": "tired"
        }
      },
      "tcsmp:on_return_home": {
        "trigger": "tcsmp:go_to_sleep"
      },
      "tcsmp:go_to_sleep": {
        "remove": {
          "component_groups": ["tcsmp:tired"]
        },
        "add": {
          "component_groups": ["tcsmp:sleeping"]
        },
        "set_property": {
          "tcsmp:seal_state": "sleeping"
        }
      },
      "tcsmp:wake_up": {
        "trigger": "tcsmp:start_strolling"
      },
      "tcsmp:start_strolling": {
        "remove": {
          "component_groups": ["tcsmp:sleeping"]
        },
        "add": {
          "component_groups": ["tcsmp:strolling"]
        },
        "set_property": {
          "tcsmp:seal_state": "strolling"
        }
      },
      "tcsmp:start_returning": {
        "remove": {
          "component_groups": ["tcsmp:strolling"]
        },
        "add": {
          "component_groups": ["tcsmp:returning"]
        },
        "set_property": {
          "tcsmp:seal_state": "returning"
        }
      }
    }
  }
}
