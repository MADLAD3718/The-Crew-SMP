            "Texture.sigil_iron",
            "Texture.sigil_netherite",
            "Texture.sigil_redstone",
            "Texture.sigil_copper",
            "Texture.sigil_gold",
            "Texture.sigil_emerald",
            "Texture.sigil_diamond",
            "Texture.sigil_lapis",
            "Texture.sigil_amethyst",
            "Texture.sigil_resin"
          ]
        }
      },
      "textures": [ "Array.sigil_material[q.property('tcsmp:faction_variant') - 1]" ]
    }
  }
}
