{
  "format_version": "1.10.0",
  "render_controllers": {
    "controller.render.grappling_hook": {
      "arrays": {
        "textures": {
          "array.textures": [
            "texture.default",
            "texture.pulling_0",
            "texture.pulling_1",
            "texture.pulling_2"
          ]
        },
        "geometries": {
          "array.geos": [
            "geometry.default",
            "geometry.pulling_0",
            "geometry.pulling_1",
            "geometry.pulling_2"
          ]
        }
      },
      "geometry": "array.geos[variable.animation_frame]",
      "materials": [ { "*": "variable.is_enchanted ? material.enchanted : material.default" } ],
      "textures": [ "array.textures[variable.animation_frame]", "texture.enchanted" ]
    }
  }
}
