{
	"format_version": "1.19.0",
	"animation_controllers": {
		"controller.animation.seal.water": {
			"initial_state": "treading",
			"states": {
				"treading": {
					"animations": ["treading"],
					"transitions": [
						{"swimming": "q.ground_speed != 0"}
					],
					"blend_transition": {
						"0.0": 1,
						"0.0444": 0.79012,
						"0.0889": 0.60494,
						"0.1333": 0.44444,
						"0.1778": 0.30864,
						"0.2222": 0.19753,
						"0.2667": 0.11111,
						"0.3111": 0.04938,
						"0.3556": 0.01235,
						"0.4": 0
					}
				},
				"swimming": {
					"animations": ["swimming"],
					"transitions": [
						{"treading": "q.ground_speed == 0"}
					],
					"blend_transition": {
						"0.0": 1,
						"0.0833": 0.96571,
						"0.1665": 0.8738,
						"0.2501": 0.74074,
						"0.3334": 0.58299,
						"0.4166": 0.41701,
						"0.4999": 0.25926,
						"0.5835": 0.1262,
						"0.6667": 0.03429,
						"0.75": 0
					}
				}
			}
		},
		"controller.animation.seal.land": {
			"states": {
				"default": {
					"animations": ["basking"],
					"transitions": [
						{"sleeping": "q.property('tcsmp:seal_state') == 'sleeping'"},
						{"galumphing": "q.modified_move_speed > 0.075"}
					],
					"blend_transition": 0.5,
					"blend_via_shortest_path": true
				},
				"sleeping": {
					"animations": ["sleeping"],
					"transitions": [
						{"default": "q.property('tcsmp:seal_state') != 'sleeping'"}
					],
					"blend_transition": 0.35
				},
				"galumphing": {
					"animations": ["galumphing"],
					"transitions": [
						{"default": "q.modified_move_speed < 0.075"}
					],
					"blend_transition": 0.5
				}
			}
		},
		"controller.animation.seal.beg": {
			"states": {
				"default": {
					"transitions": [
						{"hungry": "q.is_interested && q.property('tcsmp:seal_state') != 'sleeping'"}
					],
					"blend_transition": 0.1
				},
				"hungry": {
					"animations": ["hungry"],
					"transitions": [
						{"default": "!q.is_interested || q.property('tcsmp:seal_state') == 'sleeping'"}
					],
					"blend_transition": 0.1
				}
			}
		}
	}
}