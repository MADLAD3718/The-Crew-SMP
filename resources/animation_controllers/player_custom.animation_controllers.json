{
	"format_version" : "1.26.20",
	"animation_controllers" : {
		"controller.animation.player.grappling_hook" : {
			"initial_state" : "default",
			"states" : {
				"charge" : {
					"animations" : [ "third_person_grappling_hook_equipped" ],
					"transitions" : [
						{
							"default" : "q.get_equipped_item_name != 'grappling_hook' || q.main_hand_item_use_duration == 0.0"
						},
						{
							"hold" : "v.grappling_hook_is_charged"
						}
					]
				},
				"default" : {
					"transitions" : [
						{
							"hold" : "v.grappling_hook_is_charged"
						},
						{
							"charge" : "v.grappling_hook_is_charging"
						}
					]
				},
				"hold" : {
					"animations" : [ "crossbow_hold" ],
					"transitions" : [
						{
							"default" : "q.get_equipped_item_name != 'grappling_hook' || q.main_hand_item_use_duration == 0.0"
						},
						{
							"charge" : "v.grappling_hook_is_charging"
						}
					]
				}
			}
		},
		"controller.animation.player.katana": {
			"initial_state": "default",
			"states": {
				"default": {
                    "animations": [ "move.arms" ],
					"transitions": [
						{
							"charging": "v.katana_is_charging"
						}
					]
				},
				"charging": {
					"animations": [ "third_person_katana_charge" ],
					"transitions": [
						{
							"dashing": "q.main_hand_item_use_duration == 0.0"
						}
					]
				},
				"dashing": {
					"animations": [ "third_person_katana_dash" ],
					"transitions": [
						{
							"default": "q.any_animation_finished || q.get_equipped_item_name != 'katana'"
						}
					]
				}
			}
		},
		"controller.animation.player.first_person_map": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        {
                            "one_hand": "q.get_equipped_item_name('off_hand') == 'filled_map' || v.is_holding_shield_offhand"
                        },
                        {
                            "two_hand": "q.get_equipped_item_name('off_hand') != 'filled_map' && !v.is_holding_shield_offhand"
                        }
                    ]
                },
                "one_hand": {
                    "animations": [
                        {
                            "first_person_map_hold_main_hand": "q.get_equipped_item_name(0, 1) == 'filled_map'"
                        },
                        {
                            "first_person_map_hold_off_hand": "q.get_equipped_item_name('off_hand') == 'filled_map' && (q.get_equipped_item_name == 'bow' ? !(variable.item_use_normalized > 0 && variable.item_use_normalized < 1.0) : 1.0)"
                        }
                    ],
                    "transitions": [
                        {
                            "default": "q.get_equipped_item_name(0, 1) != 'filled_map' && q.get_equipped_item_name('off_hand') != 'filled_map'"
                        },
                        {
                            "two_hand": "q.get_equipped_item_name('off_hand') != 'filled_map' && !v.is_holding_shield_offhand"
                        }
                    ]
                },
                "two_hand": {
                    "animations": [ "first_person_map_hold", "first_person_map_hold_attack" ],
                    "transitions": [
                        {
                            "default": "q.get_equipped_item_name(0, 1) != 'filled_map' && q.get_equipped_item_name('off_hand') != 'filled_map'"
                        },
                        {
                            "one_hand": "q.get_equipped_item_name('off_hand') == 'filled_map' || v.is_holding_shield_offhand"
                        }
                    ]
                }
            }
        },
		"controller.animation.player.root" : {
			"initial_state" : "default",
			"states" : {
                "default": {
                    "transitions": [
                        {
                            "paperdoll": "v.is_paperdoll"
                        },
                        {
                            "map_player": "v.map_face_icon"
                        },
                        {
                            "first_person": "v.is_first_person"
                        },
                        {
                            "third_person": "!v.is_first_person"
                        }
                    ]
                },
				"first_person" : {
					"animations" : [
                        "first_person_base_pose",
                        "first_person_walk",
                        {
                            "first_person_swap_item": "!q.blocking"
                        },
                        {
                            "first_person_shield_block": "q.blocking"
                        },
                        {
                            "first_person_attack_controller": "v.attack_time > 0.0 && q.get_equipped_item_name != 'filled_map' && !v.melee_spear_equipped"
                        },
                        {
                            "first_person_empty_hand": "q.get_equipped_item_name(0, 1) != 'filled_map'"
                        },
                        {
                            "first_person_map_controller": "q.get_equipped_item_name(0, 1) == 'filled_map' || q.get_equipped_item_name('off_hand') == 'filled_map'"
                        },
                        {
                            "first_person_crossbow_equipped": "q.get_equipped_item_name == 'crossbow' && v.item_use_normalized > 0.0 && v.item_use_normalized < 1.0"
                        },
                        {
                            "first_person_melee_spear_controller": "v.melee_spear_equipped"
                        },
						{
							"first_person_grappling_hook_equipped": "q.get_equipped_item_name == 'grappling_hook' && v.grappling_hook_is_charging"
						},
						{
							"first_person_weild_katana": "q.get_equipped_item_name == 'katana' && v.item_use_normalized > 0"
						}
					],
                    "transitions": [
                        {
                            "paperdoll": "v.is_paperdoll"
                        },
                        {
                            "map_player": "v.map_face_icon"
                        },
                        {
                            "third_person": "!v.is_first_person"
                        }
                    ]
				},
                "map_player": {
                    "transitions": [
                        {
                            "paperdoll": "v.is_paperdoll"
                        },
                        {
                            "first_person": "v.is_first_person"
                        },
                        {
                            "third_person": "!v.map_face_icon && !v.is_first_person"
                        }
                    ]
                },
                "paperdoll": {
                    "animations": [ "humanoid_base_pose", "look_at_target_ui", "move.arms", "move.legs", "cape" ],
                    "transitions": [
                        {
                            "first_person": "!v.is_paperdoll && v.is_first_person"
                        },
                        {
                            "map_player": "v.map_face_icon"
                        },
                        {
                            "third_person": "!v.is_paperdoll && !v.is_first_person"
                        }
                    ]
                },
				"third_person" : {
					"animations" : [
                        "humanoid_base_pose",
                        {
                            "look_at_target": "!q.is_sleeping && !q.is_emoting"
                        },
                        {
                            "move.arms": "q.get_equipped_item_name != 'katana'"
                        },
                        "move.legs",
                        "cape",
                        {
                            "riding.root": "q.is_riding"
                        },
                        {
                            "riding.arms": "q.is_riding"
                        },
                        {
                            "riding.legs": "q.is_riding"
                        },
                        "holding",
                        {
                            // Refers to Trident-like items, for the Spear, see "melee_spear" animations.
                            "brandish_spear": "v.is_brandishing_spear"
                        },
                        {
                            "holding_spyglass": "v.is_holding_spyglass"
                        },
                        {
                            "charging": "q.is_charging"
                        },
                        {
                            "sneaking": "q.is_sneaking && !q.is_sleeping"
                        },
                        {
                            "bob": "!v.is_holding_spyglass && !v.is_tooting_goat_horn && !v.is_using_brush"
                        },
                        {
                            "damage_nearby_mobs": "v.damage_nearby_mobs"
                        },
                        {
                            "swimming": "v.swim_amount > 0.0 && !v.melee_spear_equipped"
                        },
                        {
                            "swimming.no_right_arm": "v.swim_amount > 0.0 && v.melee_spear_equipped"
                        },
                        {
                            "swimming.legs": "v.swim_amount > 0.0"
                        },
                        {
                            "crawling": "q.is_crawling && !v.melee_spear_equipped"
                        },
                        {
                            "crawling.no_right_arm": "q.is_crawling && v.melee_spear_equipped"
                        },
                        {
                            "crawling.legs": "q.is_crawling"
                        },
                        {
                            "use_item_progress": "( v.use_item_interval_progress > 0.0 ) || ( v.use_item_startup_progress > 0.0 ) && !v.is_brandishing_spear && !v.is_holding_spyglass && !v.is_tooting_goat_horn && !v.is_using_brush && !q.is_item_name_any('slot.weapon.mainhand', 'minecraft:bow')"
                        },
                        {
                            "sleeping": "q.is_sleeping && q.is_alive"
                        },
                        {
                            "attack.positions": "v.attack_time >= 0.0 && !v.melee_spear_equipped"
                        },
                        {
                            "attack.rotations": "v.attack_time >= 0.0 && !v.melee_spear_equipped"
                        },
                        {
                            "shield_block_main_hand": "q.blocking && !v.is_holding_shield_offhand && v.is_holding_shield_mainhand"
                        },
                        {
                            "shield_block_off_hand": "q.blocking && v.is_holding_shield_offhand"
                        },
                        {
                            "crossbow_controller": "q.get_equipped_item_name == 'crossbow'"
                        },
                        {
                            "third_person_bow_equipped": "q.get_equipped_item_name == 'bow' && (variable.item_use_normalized > 0 && variable.item_use_normalized < 1.0)"
                        },
                        {
                            "tooting_goat_horn": "v.is_tooting_goat_horn"
                        },
                        {
                            "holding_brush": "q.get_equipped_item_name == 'brush'"
                        },
                        {
                            "brushing": "v.is_using_brush"
                        },
                        {
                            "holding_heavy_core": "q.get_equipped_item_name == 'heavy_core'"
                        },
                        {
                            "third_person_melee_spear_controller": "v.melee_spear_equipped"
                        },
						{
							"grappling_hook_controller": "query.get_equipped_item_name == 'grappling_hook'"
						},
						{
							"katana_controller": "query.get_equipped_item_name == 'katana'"
						}
					],
					"transitions" : [
						{
							"paperdoll" : "v.is_paperdoll"
						},
						{
							"first_person" : "v.is_first_person"
						},
						{
							"map_player" : "v.map_face_icon"
						}
					]
				}
			}
		}
	}
}
