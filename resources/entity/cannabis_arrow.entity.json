{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "tcsmp:cannabis_arrow",
      "materials": {
        "default": "arrow"
      },
      "textures": {
        "default": "textures/entity/cannabis_arrow"
      },
      "geometry": {
        "default": "geometry.arrow"
      },
      "particle_effects": {
        "cannabis_arrowspell": "tcsmp:cannabis_arrowspell"
      },
      "animations": {
        "move": "animation.arrow.move",
        "particle": "animation.cannabis_arrow.particle"
      },
      "scripts": {
        "pre_animation": [
          "variable.shake = query.shake_time - query.frame_alpha;",
          "variable.shake_power = variable.shake > 0.0 ? -Math.sin(variable.shake * 200.0) * variable.shake : 0.0;"
        ],
        "animate": [ "move", "particle" ]
      },
      "render_controllers": [ "controller.render.default" ]
    }
  }
}