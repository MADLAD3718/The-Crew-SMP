{
  "namespace": "chest",

  "small_chest_screen@common.inventory_screen_common": {
    "$title": "$container_title",
    "$new_container_title|default": "$container_title",
    "$container_size|default": 27,
    "variables": [
      {
        "requires": "(($desktop_screen) and ($title = '§C§A§N§N§O§N'))",
        "$screen_content": "redstone.dispenser_screen",
        "$screen_bg_content": "common.screen_background",
        "$screen_background_alpha": 0.2,
        "$new_container_title": "entity.tcsmp:cannon.name"
      },
      {
        "requires": "(($pocket_screen) and ($title = '§C§A§N§N§O§N'))",
        "$use_custom_pocket_toast": true,
        "$screen_content": "pocket_containers.panel",
        "$new_container_title": "entity.tcsmp:cannon.name",
        "$container_size": 9
      },
      {
        "requires": "(($desktop_screen) and (not ($title = '§C§A§N§N§O§N')))",
        "$screen_content": "chest.small_chest_panel",
        "$screen_bg_content": "common.screen_background",
        "$screen_background_alpha": 0.4
      },
      {
        "requires": "(($pocket_screen) and (not ($title = '§C§A§N§N§O§N')))",
        "$use_custom_pocket_toast": true,
        "$screen_content": "pocket_containers.small_chest_panel"
      }
    ]
  }

}