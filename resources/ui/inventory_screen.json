{
    "namespace": "crafting",

    "slot_overlay": {
        "type": "image",
        "layer": 2,
        "$slot_overlay_size|default": [ 16, 16 ],
        "size": "$slot_overlay_size",
        "bindings": [
            {
                "binding_name": "#item_id_aux",
                "binding_type": "collection",
                "binding_collection_name": "$item_collection_name"
            },
            {
                "binding_type": "view",
                "source_property_name": "(#item_id_aux = -1)",
                "target_property_name": "#visible"
            }
        ]
    },

    "slot_overlay_paper@slot_overlay": {
        "texture": "textures/ui/empty_inscription_slot_paper"
    },

    "slot_overlay_lapis@slot_overlay": {
        "texture": "textures/ui/empty_inscription_slot_lapis"
    },

    "inscription_grid_3x3": {
        "type": "grid",
        "size": [ 54, 54 ],
        "anchor_from": "top_left",
        "anchor_to": "top_left",
        "grid_dimensions": [ 3, 3 ],
        "collection_name": "crafting_input_items",
        "controls": [
            {
                "crafting_input_item_top_left@crafting.crafting_input_grid_item": {
                    "grid_position": [ 0, 0 ],

                    "$focus_id_binding_type": "none",
                    "$focus_id": "crafting_input_top_left",

                    "$focus_override_left_binding_type": "none",
                    "$focus_override_left": "armor_item_head",
                    
                    "$cell_overlay_ref": "crafting.slot_overlay_lapis"
                }
            },
            {
                "crafting_input_item_top_mid@crafting.crafting_input_grid_item": {
                    "grid_position": [ 1, 0 ],

                    "$cell_overlay_ref": "crafting.slot_overlay_lapis"
                }
            },
            {
                "crafting_input_item_top_right@crafting.crafting_input_grid_item": {
                    "grid_position": [ 2, 0 ],

                    "$cell_overlay_ref": "crafting.slot_overlay_lapis"
                }
            },
            {
                "crafting_input_item_mid_left@crafting.crafting_input_grid_item": {
                    "grid_position": [ 0, 1 ],

                    "$focus_id_binding_type": "none",
                    "$focus_id": "crafting_input_mid_left",

                    "$focus_override_left_binding_type": "none",
                    "$focus_override_left": "armor_item_legs",

                    "$cell_overlay_ref": "crafting.slot_overlay_lapis"
                }
            },
            {
                "crafting_input_item_middle@crafting.crafting_input_grid_item": {
                    "grid_position": [ 1, 1 ],
                    
                    "$cell_overlay_ref": "crafting.slot_overlay_paper"
                }
            },
            {
                "crafting_input_item_mid_right@crafting.crafting_input_grid_item": {
                    "grid_position": [ 2, 1 ],

                    "$cell_overlay_ref": "crafting.slot_overlay_lapis"
                }
            },
            {
                "crafting_input_item_bot_left@crafting.crafting_input_grid_item": {
                    "grid_position": [ 0, 2 ],

                    "$cell_overlay_ref": "crafting.slot_overlay_lapis"
                }
            },
            {
                "crafting_input_item_bot_mid@crafting.crafting_input_grid_item": {
                    "grid_position": [ 1, 2 ]
                }
            },
            {
                "crafting_input_item_bot_right@crafting.crafting_input_grid_item": {
                    "grid_position": [ 2, 2 ],

                    "$focus_override_right_binding_type": "none",
                    "$focus_override_right": "crafting_output_item",

                    "$cell_overlay_ref": "crafting.slot_overlay_lapis"
                }
            }
        ]
    },

    "crafting_grid_3x3_with_label/crafting_grid_3x3": {
        "modifications": [
            {
                "array_name": "bindings",
                "operation": "insert_back",
                "value": {
                    "binding_name": "#crafting_label_text",
                    "binding_name_override": "#text"
                }
            },
            {
                "array_name": "bindings",
                "operation": "insert_back",
                "value": {
                    "binding_type": "view",
                    "source_property_name": "((#text - '§I§N§S§C§R§I§P§T§I§O§N') = #text)",
                    "target_property_name": "#visible"
                }
            }
        ]
    },

    "crafting_grid_3x3_with_label": {
        "modifications": [
            {
                "array_name": "controls",
                "operation": "insert_back",
                "value": {
                    "inscription_crafting_grid_3x3@crafting.inscription_grid_3x3": {
                        "offset": [ 0, 11 ],
                        "bindings": [
                            {
                                "binding_name": "#crafting_label_text",
                                "binding_name_override": "#text"
                            },
                            {
                                "binding_type": "view",
                                "source_property_name": "(not ((#text - '§I§N§S§C§R§I§P§T§I§O§N') = #text))",
                                "target_property_name": "#visible"
                            }
                        ]
                    }
                }
            }
        ]
    }

}
