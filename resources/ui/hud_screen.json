{
  "namespace": "hud",

  "root_panel": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_front",
        "value": [
          {
            "overlay_storage@title_text_storage": {
              "$update_key": "overlay: "
            }
          },
          {
            "barnacle_tongue_overlay@conditional_screen_overlay": {
              "$storage_field": "overlay_storage",
              "$visible_value": "tongue",
              "texture": "textures/ui/barnacle_effect"
            }
          },
          {
            "flash_storage@title_text_storage": {
              "$update_key": "flash: "
            }
          }
        ]
      }
    ]
  },

  "centered_gui_elements_at_bottom_middle": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_front",
        "value": [
          {
            "heart_over@hud.heart_overlay" : {
              "offset": [ -1, -32 ],
              "anchor_from": "bottom_left",
              "anchor_to": "bottom_left",
              "$storage_field": "flash_storage",
              "$visible_value": "on"
            }
          }
        ]
      }
    ]
  },

  "title_text_storage": {
    "type": "panel",
    "property_bag": {
      "#stored_title_text": "",
      "#stored_value": ""
    },
    "bindings": [
      {
        "binding_name": "#hud_title_text_string"
      },
      {
        "binding_name": "#hud_title_text_string",
        "binding_name_override": "#stored_title_text",
        "binding_condition": "visibility_changed"
      },
      {
        "binding_type": "view",
        "source_property_name": "(#stored_title_text - $update_key)",
        "target_property_name": "#stored_value"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not (#hud_title_text_string = #stored_title_text) and not ((#hud_title_text_string - $update_key) = #hud_title_text_string))",
        "target_property_name": "#visible"
      }
    ]
  },

  "conditional_element": {
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "$storage_field",
        "source_property_name": "#stored_value",
        "target_property_name": "#text"
      },
      {
        "binding_type": "view",
        "source_property_name": "(#text = $visible_value)",
        "target_property_name": "#visible"
      }
    ]
  },

  "conditional_screen_overlay@conditional_element": {
    "type": "image",
    "keep_ratio": false
  },

  "hud_title_text/title_frame/title": {
    "modifications": [
      {
        "array_name": "bindings",
        "operation": "insert_back",
        "value": {
          "binding_type": "view",
          "source_property_name": "((#text - 'overlay: ' - 'flash: ') = #text)",
          "target_property_name": "#visible"
        }
      }
    ]
  },

  "chat_label": {
    "modifications": [
      {
        "array_name": "bindings",
        "operation": "insert_back",
        "value": [
          {
            "binding_type": "view",
            "source_property_name": "(not (('%.21s' * #text = '§U§N§I§C§O§R§N') or ('%.18s' * #text = '§C§A§N§N§O§N') or ('%.18s' * #text = '§G§E§R§B§I§L') or ('%.7s' * #text = 'Unknown')))",
            "target_property_name": "#visible"
          }
        ]
      }
    ]
  },

  "hud_actionbar_text": {
    "layer": 31
  },

  "heart_outline": {
    "type": "image",
    "texture": "textures/ui/heart_outline",
    "size": [ 9, 9 ],
    "anchor_from": "left_middle",
    "anchor_to": "left_middle",
    "layer": 2,
    "bindings": [
      {
        "binding_name": "#show_survival_ui",
        "binding_name_override": "#visible"
      }
    ]
  },

  "heart_overlay@conditional_element": {
    "type": "panel",
    "size": [ 81, 9 ],
    "controls": [
      { "0@hud.heart_outline": { "offset": [ 0, 0 ] } },
      { "1@hud.heart_outline": { "offset": [ 8, 0 ] } },
      { "2@hud.heart_outline": { "offset": [ 16, 0 ] } },
      { "3@hud.heart_outline": { "offset": [ 24, 0 ] } },
      { "4@hud.heart_outline": { "offset": [ 32, 0 ] } },
      { "5@hud.heart_outline": { "offset": [ 40, 0 ] } },
      { "6@hud.heart_outline": { "offset": [ 48, 0 ] } },
      { "7@hud.heart_outline": { "offset": [ 56, 0 ] } },
      { "8@hud.heart_outline": { "offset": [ 64, 0 ] } },
      { "9@hud.heart_outline": { "offset": [ 72, 0 ] } }
    ]
  }

}