{
  "format_version": "1.10.0",
  "minecraft:attachable": {
    "description": {
      "identifier": "tcsmp:katana",
      "materials": {
        "default": "entity_alphatest",
        "enchanted": "entity_alphatest_glint"
      },
      "textures": {
        "default": "textures/items/katana",
        "enchanted": "textures/misc/enchanted_item_glint"
      },
      "geometry": {
        "default": "geometry.katana"
      },
      "animations": {
        "root": "controller.animation.katana",
        "wield": "animation.katana.wield",
        "charge": "animation.katana.charge",
        "hold": "animation.katana.hold",
        "dash": "animation.katana.dash"
      },
      "scripts": {
        "pre_animation": [
          "variable.use_time = 20.0 * 0.5;",
          "variable.charge_amount = math.clamp((query.main_hand_item_max_duration - (query.main_hand_item_use_duration - query.frame_alpha + 1.0)) / v.use_time, 0.0, 1.0f);"
        ],
        "animate": [
          "wield",
          "root"
        ]
      },
      "render_controllers": [ "controller.render.katana" ]
    }
  }
}
