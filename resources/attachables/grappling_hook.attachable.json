{
  "format_version": "1.10.0",
  "minecraft:attachable": {
    "description": {
      "identifier": "tcsmp:grappling_hook",
      "materials": {
        "default": "entity_alphatest",
        "enchanted": "entity_alphatest_glint"
      },
      "textures": {
        "default": "textures/items/grappling_hook/grappling_hook",
        "pulling_0": "textures/items/grappling_hook/grappling_hook_pulled_0",
        "pulling_1": "textures/items/grappling_hook/grappling_hook_pulled_1",
        "pulling_2": "textures/items/grappling_hook/grappling_hook_pulled_2",
        "enchanted": "textures/misc/enchanted_item_glint"
      },
      "geometry": {
        "default": "geometry.grappling_hook",
        "pulling_0": "geometry.grappling_hook_pulling_0",
        "pulling_1": "geometry.grappling_hook_pulling_1",
        "pulling_2": "geometry.grappling_hook_pulling_2"
      },
      "animations": {
        "wield": "animation.grappling_hook.wield",
        "wield_first_person_pull": "animation.grappling_hook.wield_first_person_pull"
      },
      "scripts": {
        "pre_animation": [
          "variable.max_use_duration = 1.0;", // Defined in seconds
          "variable.item_use_normalized = (q.main_hand_item_max_duration - q.main_hand_item_use_duration) / (20 * v.max_use_duration);",
          "variable.item_is_charged = q.main_hand_item_use_duration != 0.0 && v.item_use_normalized >= 1.0;",
          "variable.animation_frame = v.item_is_charged ? 3 : math.floor(v.item_use_normalized * 4);"
        ],
        "animate": [
          "wield",
          {
            "wield_first_person_pull": "query.main_hand_item_use_duration > 0.0f && c.is_first_person"
          }
        ]
      },
      "render_controllers": [ "controller.render.grappling_hook" ]
    }
  }
}
