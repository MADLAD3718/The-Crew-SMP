                    "position": [ 0.0, "-10.0 * (1.0 - c.player_offhand_arm_height)", 0.0 ]
                },
                "rightarm": {
                    "position": [ 0.0, "!v.is_holding_shield_offhand ? -10.0 * (1.0 - v.player_arm_height) : 0.0", 0.0 ]
                }
            }
        },
		"animation.player.first_person.grappling_hook_equipped": {
			"loop": true,
