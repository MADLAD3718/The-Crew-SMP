				"root": {
					"rotation": ["90 + q.ride_body_x_rotation - 5 * math.sin((q.life_time + 0.2) * 360)", 0, 0],
					"position": [
						0,
						"7.5 + 17.5 * (1 + math.sin(q.ride_body_x_rotation - 5 * math.sin((q.life_time + 0.2) * 360))) + 2 * math.sin(q.life_time * 360)",
						"17.5 * math.cos(q.ride_body_x_rotation - 5 * math.sin((q.life_time + 0.2) * 360)) + 8.5 + 1.5 * math.sin((q.life_time + 0.2) * 360)"
					]
				},
