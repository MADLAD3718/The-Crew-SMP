				},
				"rightArm": {
					"rotation": ["-115 - q.ride_body_x_rotation - 6.5 * math.sin((q.life_time + 0.2) * 360)", 0, 0]
				},
				"leftLeg": {
					"rotation": ["-10 * math.sin((q.life_time - 0.05) * 360)", 0, 0]
				},
				"rightLeg": {
					"rotation": ["-10 * math.sin((q.life_time - 0.0) * 360)", 0, 0]
				}
			}
