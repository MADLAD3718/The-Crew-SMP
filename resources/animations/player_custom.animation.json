                    "position": [ "v.is_holding_shield_offhand ? -4.0 : 0.0", 0.0, 0.0 ]
                }
            }
        },
        "animation.player.first_person.swap_item": {
            "loop": true,
            "bones": {
                "leftarm": {
                    "position": [ 0.0, "(q.get_equipped_item_name('off_hand') == 'filled_map' || v.is_holding_shield_offhand) ? 0.0 : -10.0 * (1.0 - c.player_offhand_arm_height)", 0.0 ]
                },
                "rightarm": {
                    "position": [ 0.0, "-10.0 * (1.0 - v.player_arm_height)", 0.0 ]
                }
            }
        },
        "animation.player.first_person.shield_block": {
