				}
			}
		},
		"animation.player.first_person.katana.weild": {
			"loop": true,
			"override_previous_animation": true,
			"bones": {
				"leftArm": {
					"rotation": ["145 + 10 * v.katana_use_norm", "-60 - 30 * v.katana_use_norm", 45],
					"position": ["1.0 - (1.0 - v.katana_use_norm) * 1.5", "-3.5 + v.short_arm_offset_left - v.katana_use_norm", "9.25 - v.katana_use_norm"],
