				},
				"rightArm": {
					"rotation": ["- 60.0 - this + v.katana_use_norm * 50", "- 15.0 - this", "- 2.5 - this"]
				}
			}
		},
		"animation.player.katana.dash": {
			"loop": true,
			"animation_length": 0.4,
