{
	"format_version": "1.8.0",
	"animations": {
		"animation.unicorn.baby_transform": {
			"loop": true,
			"bones": {
				"Body": {
					"position": [0, "11 * ((0.0625 - query.model_scale) * 16.0)", 0]
				},
				"Head": {
					"scale": "1.0 + 0.5 * (1.0 - (query.model_scale * 16.0))"
				},
				"LegBL": {
					"scale": [1, "1.0 + ((0.0625 - query.model_scale) * 16.0)", 1]
				},
				"LegBR": {
					"scale": [1, "1.0 + ((0.0625 - query.model_scale) * 16.0)", 1]
				},
				"LegFL": {
					"scale": [1, "1.0 + ((0.0625 - query.model_scale) * 16.0)", 1]
				},
				"LegFR": {
					"scale": [1, "1.0 + ((0.0625 - query.model_scale) * 16.0)", 1]
				}
			}
		},
		"animation.unicorn.eat": {
			"loop": true,
			"bones": {
				"Neck": {
					"rotation": ["variable.eat_anim * (110.0 + math.sin((query.life_time * 20.0) * 57.3) * 2.86)", 0, 0]
				}
			}
		},
		"animation.unicorn.look_at_player": {
			"loop": true,
			"bones": {
				"Neck": {
					"rotation": [
						"variable.head_x_rot",
						"math.clamp((variable.stand_anim + variable.inverse_max_stand_eat) * query.head_y_rotation(0) - q.body_y_rotation, -20, 20)",
						0
					]
				}
			}
		},
		"animation.unicorn.rear": {
			"loop": true,
			"bones": {
				"Body": {
					"rotation": ["-45.0 * variable.stand_anim", 0, 0]
				},
				"LegBL": {
					"rotation": ["45.0 * variable.stand_anim", 0, 0]
				},
				"LegBR": {
					"rotation": ["45.0 * variable.stand_anim", 0, 0]
				},
				"LegFL": {
					"rotation": ["(-60.0 + math.cos((query.life_time * 20.0) * 34.38) * 57.3) * variable.stand_anim", 0, 0]
				},
				"LegFR": {
					"rotation": ["(-60.0 - math.cos((query.life_time * 20.0) * 34.38) * 57.3) * variable.stand_anim", 0, 0]
				},
				"Neck": {
					"rotation": ["(15.0 + variable.head_x_rot) * variable.stand_anim", 0, 0]
				},
				"Tail": {
					"rotation": ["55.0 * variable.stand_anim", 0, 0]
				}
			}
		},
		"animation.unicorn.tail": {
			"loop": true,
			"bones": {
				"Tail": {
					"rotation": [0, "math.cos(query.life_time * 802.0) * 57.3", 0]
				}
			}
		},
		"animation.unicorn.walk": {
			"loop": true,
			"bones": {
				"BagL": {
					"rotation": ["variable.leg_x_rot_anim / 5.0", 0, 0]
				},
				"BagR": {
					"rotation": ["-variable.leg_x_rot_anim / 5.0", 0, 0]
				},
				"LegBL": {
					"rotation": ["(-variable.leg_stand_factor * 57.2 * query.modified_move_speed) * (1.0 - variable.stand_anim)", 0, 0]
				},
				"LegBR": {
					"rotation": ["(variable.leg_stand_factor * 57.2 * query.modified_move_speed) * (1.0 - variable.stand_anim)", 0, 0]
				},
				"LegFL": {
					"rotation": ["variable.leg_x_rot_anim * (1.0 - variable.stand_anim)", 0, 0]
				},
				"LegFR": {
					"rotation": ["-variable.leg_x_rot_anim * (1.0 - variable.stand_anim)", 0, 0]
				},
				"Tail": {
					"rotation": ["q.modified_move_speed * 40 + v.head_x_rot", 0, 0]
				}
			}
		},
		"animation.unicorn.idle": {
			"loop": true,
			"animation_length": 0.5,
			"particle_effects": {
				"0.0": {
					"effect": "horn",
					"locator": "horn"
				}
			}
		},
		"animation.unicorn.trail": {
			"loop": true,
			"animation_length": 0.025,
			"particle_effects": {
				"0.0": {
					"effect": "trail",
					"locator": "trail"
				}
			}
		},
		"animation.unicorn.gallop": {
			"loop": true,
			"animation_length": 0.5,
			"sound_effects": {
				"0.0": {
					"effect": "gallop",
					"locator": "gallop"
				}
			}
		},
		"animation.unicorn.trail_sound": {
			"loop": true,
			"animation_length": 0.75,
			"sound_effects": {
				"0.0": {
					"effect": "trail",
					"locator": "trail"
				}
			}
		}
	}
}