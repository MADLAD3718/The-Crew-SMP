{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "tcsmp:katana_dash",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/particle/particles"
			}
		},
		"components": {
			"minecraft:emitter_rate_instant": {
				"num_particles": 200
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1
			},
			"minecraft:emitter_shape_box": {
				"offset": [0, 0.9, 0],
				"half_dimensions": [0.3, 0.9, 0.3],
				"direction": ["v.direction.x", 0, "v.direction.z"]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "0.75 + 1.5 * v.particle_random_3 - (1.0 - v.particle_random_1)"
			},
			"minecraft:particle_initial_spin": {
				"rotation_rate": "270 * (v.particle_random_3 < 0.5 ? 1 : -1)"
			},
			"minecraft:particle_initial_speed": "3 + 50 * v.particle_random_1",
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": ["3 * math.cos(-(v.particle_age / v.particle_lifetime + v.particle_random_2) * 360)", "(2 + 3 * (1.0 - v.particle_random_1))", "3 * math.sin(-(v.particle_age / v.particle_lifetime + v.particle_random_2) * 360)"],
				"linear_drag_coefficient": 5
			},
			"minecraft:particle_appearance_billboard": {
				"size": [0.03, 0.03],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 128,
					"texture_height": 128,
					"uv": [4, 4],
					"uv_size": [1, 1]
				}
			},
			"minecraft:particle_motion_collision": {
				"collision_radius": 0.025
			},
			"minecraft:particle_appearance_tinting": {
				"color": ["0.75 - 0.5 * v.particle_random_1", 1, 1, "1 - math.pow(v.particle_age / v.particle_lifetime, 3)"]
			}
		}
	}
}