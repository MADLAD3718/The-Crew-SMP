{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "tcsmp:cannon_smoke",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "textures/particle/campfire_smoke"
			}
		},
		"components": {
			"minecraft:emitter_rate_instant": {
				"num_particles": 1
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 2
			},
			"minecraft:emitter_shape_point": {
				"direction": ["v.direction.x", "v.direction.y", "v.direction.z"]
			},
			"minecraft:particle_initialization": {
				"per_update_expression": "variable.r = 0.75;variable.u = variable.particle_random_2 * (1 - math.sqrt(1 - variable.r * variable.r));variable.sint = math.sqrt(variable.u * (2 - variable.u));variable.phi = 360 * variable.particle_random_3;"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 2
			},
			"minecraft:particle_initial_speed": 2,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, 0, 0],
				"linear_drag_coefficient": 1
			},
			"minecraft:particle_appearance_billboard": {
				"size": [0.5, 0.5],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 16,
					"texture_height": 192,
					"uv": [0, "16 * math.floor(12 * variable.particle_random_1)"],
					"uv_size": [16, 16]
				}
			},
			"minecraft:particle_appearance_lighting": {},
			"minecraft:particle_appearance_tinting": {
				"color": [1, 1, 1, "0.75 * (1 - math.pow(variable.particle_age / variable.particle_lifetime, 4))"]
			}
		}
	}
}