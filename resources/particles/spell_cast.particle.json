{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "tcsmp:spell_cast",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/particle/particles"
			}
		},
		"components": {
			"minecraft:emitter_rate_instant": {
				"num_particles": 100
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 5
			},
			"minecraft:emitter_shape_sphere": {
				"radius": 1,
				"direction": "outwards"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "3 + 2 * v.particle_random_3"
			},
			"minecraft:particle_initial_speed": 8,
			"minecraft:particle_motion_dynamic": {
				"linear_drag_coefficient": 4.5
			},
			"minecraft:particle_appearance_billboard": {
				"size": [0.2, 0.2],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 128,
					"texture_height": 128,
					"uv": ["8 * math.floor(v.particle_random_1 * (16 - 5 * math.floor(v.particle_random_2 * 2)))", "112 + 8 * math.floor(v.particle_random_2 * 2)"],
					"uv_size": [8, 8]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": ["v.colour.r", "v.colour.g", "v.colour.b", "1.0 - math.pow(v.particle_age / v.particle_lifetime, 4)"]
			}
		}
	}
}