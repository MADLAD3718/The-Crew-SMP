{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "tcsmp:faded_wilter",
			"basic_render_parameters": {
				"material": "particles_alpha",
				"texture": "textures/particle/faded_wilter"
			}
		},
		"components": {
			"minecraft:emitter_rate_instant": {
				"num_particles": 15
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1
			},
			"minecraft:emitter_shape_point": {},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "1.25 + v.particle_random_3 * 0.5"
			},
			"minecraft:particle_initial_speed": 1,
			"minecraft:particle_motion_parametric": {
				"relative_position": [
					"v.aabb.x * math.cos(360 * (v.particle_age / 2 + v.particle_random_1))",
					"v.aabb.y * v.particle_random_2 + v.particle_age",
					"v.aabb.z * math.sin(360 * (v.particle_age + v.particle_random_1))"
				]
			},
			"minecraft:particle_appearance_billboard": {
				"size": [0.2, 0.2],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 64,
					"texture_height": 8,
					"flipbook": {
						"base_UV": [56, 0],
						"size_UV": [8, 8],
						"step_UV": [-8, 0],
						"max_frame": 8,
						"stretch_to_lifetime": true
					}
				}
			},
			"minecraft:particle_appearance_lighting": {},
			"minecraft:particle_appearance_tinting": {
				"color": [
					"variable.particle_random_4 * 0.3 + 0.15",
					"variable.particle_random_4 * 0.3 + 0.41",
					"variable.particle_random_4 * 0.3 + 0.25"
				]
			}
		}
	}
}